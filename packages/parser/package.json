{
  "name": "@electrodsl/parser",
  "version": "0.1.0",
  "description": "Reference ElectroDSL parser",
  "type": "module",

  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },

  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },

  "dependencies": {
    "@electrodsl/ast": "workspace:*",
    "chevrotain": "^12.0.0"
  },

  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}